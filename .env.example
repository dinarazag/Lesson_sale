# Скопируйте в .env перед сборкой (локально или на сервере):
#   cp .env.example .env
#
# Переменные VITE_* подставляются при сборке (npm run build / Docker build).

# Порт, на котором сайт будет доступен с хоста (только для docker compose)
APP_PORT=8080

# Идентификатор приложения (опционально)
VITE_APP_ID=local

# Если позже подключите Base44 API — укажите здесь
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=

# Если сайт открывается не в корне домена, а в подпапке, например /app/
# VITE_BASE_PATH=/app/
